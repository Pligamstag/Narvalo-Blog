# ============================================================
# .env — Variables d'environnement
# Encre & Mémoire — Backend
#
# ⚠️  NE PAS COMMITER CE FICHIER en production !
#     Ajoutez .env dans votre .gitignore
# ============================================================

# Port du serveur Express
PORT=3000

# URI de connexion MongoDB
# En local avec MongoDB installé :
MONGO_URI=mongodb://localhost:27017/encre_memoire

# Secret JWT — CHANGEZ IMPÉRATIVEMENT en production !
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=c52981a0ff9c517a20851c5964795bd9104007229e7874714d8658acfc7c51c368249fe310d09a0515aa95475d2ba9e363464a23d8b375a1d7c011d220765f0d

# Durée de validité du token JWT (ex : 8h, 1d, 7d)
JWT_EXPIRES=8h
